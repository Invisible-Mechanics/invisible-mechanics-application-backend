# --- Database ---
DATABASE_URL=postgresql+asyncpg://im:im@localhost:5432/im_liveclass

# --- Session JWT ---
# HS256 secret for our own session tokens. MUST match APP_JWT_SECRET on the
# web app (../inv-mech/.env.local). Generate with `openssl rand -hex 32`.
APP_JWT_SECRET=replace-with-32-byte-hex
# Magic link / OTP code validity (minutes). Default 15.
MAGIC_LINK_TTL_MIN=15
# Session cookie validity (hours). Default 2.
SESSION_TTL_HOURS=2

# --- CORS ---
WEB_ORIGIN=http://localhost:3000

# --- Email (Resend) ---
# Get a key at https://resend.com/api-keys
# Leave blank to use the in-memory FakeEmailClient (dev only).
RESEND_API_KEY=
MAIL_FROM=Invisible Mechanics <onboarding@resend.dev>

# --- SMS OTP (MSG91) ---
# Auth key is backend-only. Never commit the real value.
MSG91_AUTH_KEY=
MSG91_SENDER_ID=INVMEC
MSG91_TEMPLATE_ID=6a3bfbc30cdff537840d5983
MSG91_ENROLLMENT_TEMPLATE_ID=6a3fe5e3e1a64bb4ca04d0f2
MSG91_OTP_EXPIRY_MIN=15
MASTERCLASS_TOPIC_TITLE=The Art of Problem Solving
MASTERCLASS_LIVE_AT_TEXT=6 July 2026, 6:00 PM IST

# --- Razorpay (one-time payments) ---
# Generate test keys at Dashboard -> Account & Settings -> API Keys (Test Mode).
# Key ID is public (used by the browser checkout); secret is backend-only.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
# Set after creating a webhook (Developers -> Webhooks); used to verify webhook signatures.
RAZORPAY_WEBHOOK_SECRET=

# --- Cloudflare (Stream Live + on-demand) ---
# Account-scoped API token with Stream:Edit. Re-create on a new account with
# the same scopes; never commit. Leave blank to use in-process Fake clients
# (dev/tests only — no real live inputs, no real playback).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Zone is only needed if/when the app calls DNS or zone-scoped APIs. Safe to
# leave blank if you only use Stream.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ZONE_NAME=
CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4

# Customer code: part of the playback hostname customer-<code>.cloudflarestream.com.
# Find it in the Cloudflare Stream dashboard or any video's playback URL.
CLOUDFLARE_STREAM_CUSTOMER_CODE=
# Signing key id + PEM: POST /accounts/{account_id}/stream/keys returns these.
# The PEM is base64-encoded in the API response; decode before pasting. In env
# managers that strip newlines, escape line breaks as \n — the app un-escapes.
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_KEY_PEM=
# Signed playback token lifetime (seconds). Applies to both live HLS and
# post-class recording playback.
STREAM_TOKEN_TTL_SEC=21600
# Keep recordings around for this many days after a live broadcast ends.
# Passed through to Cloudflare when creating the live input.
STREAM_RECORDING_RETENTION_DAYS=30
# Cloudflare Stream webhook signing secret. Returned by Cloudflare when you
# subscribe a webhook URL via PUT /accounts/{id}/stream/webhook. Used to
# verify the Webhook-Signature header on POST /stream/webhook. Leave blank to
# disable webhook ingestion (the cron poller is the fallback).
CLOUDFLARE_STREAM_WEBHOOK_SECRET=
# Grace window (minutes) after scheduled end before a Cloudflare disconnect
# event is allowed to flip a class to "ended". Short disconnects inside the
# window are treated as transient encoder hiccups.
STREAM_END_GRACE_MIN=5

# --- Cron ---
# Shared secret required in the X-Cron-Token header on /cron/* endpoints.
# In prod, set this to a random string and configure your scheduler to send it.
CRON_SHARED_SECRET=dev

# --- App ---
ENV=dev
LOG_LEVEL=INFO
